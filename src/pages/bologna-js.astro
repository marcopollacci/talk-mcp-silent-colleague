---
import favicon from "../img/bolognajs_favicon.png";
import qrLinkRating from "../img/qrcode_bolognajs_rating.png";
import qrLinkTalk from "../img/qrcode_bolognajs_talk.png";
import Layout from "../layouts/Layout.astro";
import BolognaJsTalks from "../slides/bolognajs-talks.astro";
import CoverBolognaJs from "../slides/cover-bologna-js.astro";
import Cover from "../slides/cover.astro";
import Intro from "../slides/intro.astro";
import McpArchitecture from "../slides/mcp-architecture.astro";
import McpHttpOauth2 from "../slides/mcp-http-oauth2.astro";
import McpHttp from "../slides/mcp-http.astro";
import McpOutro from "../slides/mcp-outro.astro";
import McpStdio from "../slides/mcp-stdio.astro";
import McpStructure from "../slides/mcp-structure.astro";
import Repo from "../slides/repo.astro";
import Thanks from "../slides/thanks.astro";
const favIcon = favicon.src;
const canRender = import.meta.env.DEV || new Date("2026-05-27") < new Date();
const metaData = {
  title: "MCP: the silent colleague connecting your services to the AI",
  description: "Talk di Marco Pollacci",
  image: "og-image.png",
  site: "https://talk-mcp-silent-colleague.marcotalk.dev/bologna-js/",
};
---

<Layout {canRender} {favIcon} {metaData}>
  <CoverBolognaJs />
  {
    canRender && (
      <>
        <Cover />
        <BolognaJsTalks />
        <Intro />
        <McpStructure />
        <McpArchitecture />
        <McpStdio />
        <McpHttp />
        <McpHttpOauth2 />
        <McpOutro />
        <Thanks
          qrLinkRating={qrLinkRating}
          qrLink={qrLinkTalk}
          urlLink={metaData.site}
          RepoSlide={Repo}
        />
      </>
    )
  }
</Layout>
