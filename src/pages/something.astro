---
import favicon from "../img/favicon.svg";
import Layout from "../layouts/Layout.astro";
import CoverSomething from "../slides/cover-something.astro";
import Cover from "../slides/cover.astro";
import Thanks from "../slides/thanks.astro";
const favIcon = favicon.src;
const canRender = import.meta.env.DEV || new Date("2050-12-31") < new Date();
const metaData = {
  title: "Something",
  description: "Talk di Marco Pollacci",
  image: "og-image.png",
  site: "",
};
---

<Layout {canRender} {favIcon} {metaData}>
  <CoverSomething />
  {
    canRender && (
      <>
        <Cover />
        <Thanks />
      </>
    )
  }
</Layout>
