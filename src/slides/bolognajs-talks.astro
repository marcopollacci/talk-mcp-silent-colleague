---
import { Image } from "astro:assets";
import qrAngularSignal from "../img/qrcode_angular-signal.pages.dev.png";
import qrAngularWebWorker from "../img/qrcode_angular-webworker.pages.dev.png";
import bolojs from "../img/bolognajs-logo.svg?url";
---

<p-slide>
  <h4 class="main-gradient">
    Your Yearly Shot of Angular at
    <object
      style="width: auto; height: 1.5em"
      data={bolojs}
      type="image/svg+xml"></object>
  </h4>
  <div class="hand-drawing center mid-dimension">
    <p-fragment
      ><span data-box style="display: flex; align-items: center"
        >17/04/2024: <span
          style="margin-inline-start: 0.4em"
          class="main-sub-gradient">Angular e Signal</span
        ><Image
          style="--image-start-size: 4em"
          class="alter-image-size"
          src={qrAngularSignal}
          alt="qrcode_angular-signal.pages.dev"
        /></span
      ></p-fragment
    >
    <p-fragment
      ><span data-arrow data-down></span><span
        data-box
        style="display: flex; align-items: center"
        >16/04/2025: <span
          style="margin-inline-start: 0.4em"
          class="main-sub-gradient">Angular e Web Worker</span
        ><Image
          style="--image-start-size: 4em"
          class="alter-image-size"
          src={qrAngularWebWorker}
          alt="qrcode_angular-web-worker.pages.dev"
        /></span
      ></p-fragment
    >
    <p-fragment
      ><span data-arrow data-down></span>
      <span data-box
        >Today: <span class="main-sub-gradient"
          >No more Angular talk, welcome of the MCP</span
        ></span
      ></p-fragment
    >
  </div>
</p-slide>
<script>
  const target = document.querySelector("object")!;

  target.addEventListener("loadeddata", () => {
    const svgDoc = target.contentDocument;
    const style = document.createElement("style");

    style.textContent = "path { stroke: #808080; }";
    svgDoc!.querySelector("svg")!.appendChild(style);
  });
</script>
<style lang="scss">
  h4 {
    margin-block-end: 1.5rem;
  }
  .mid-dimension {
    margin-block-end: 0;
  }
  .main-sub-gradient {
    background: linear-gradient(90deg, #ff00d8, #ff542f);
    font-family: "Graphik Semibold", serif;
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: rgba(0, 0, 0, 0);
  }
  .hand-drawing {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-wrap: nowrap;
    row-gap: 0.3em;
    p-fragment {
      display: flex;
      flex-direction: column;
      align-items: center;
      flex-wrap: nowrap;
      row-gap: 0.3em;
    }
    --color-border: #000000;
    span {
      &[data-box] {
        padding: 0.3em;
        background: transparent;
        outline: none;
        border: 2px solid var(--color-border);
        border-radius: 255px 15px 225px 15px / 15px 225px 15px 255px;
      }
      &[data-arrow] {
        font-size: 1.5em;
        &[data-left]:before {
          content: "\27F5";
        }
        &[data-right]:before {
          content: "\27F6";
        }
        &[data-up]:before {
          content: "\2191";
        }
        &[data-down]:before {
          content: "\2193";
        }
        &[data-up-down]:before {
          content: "\21F5";
        }
      }
    }
  }

  .property-hand-drawing-horizontal {
    flex-direction: row;
    align-items: flex-start;
  }

  .hand-drawing-horizontal {
    @extend .hand-drawing;
    @extend .property-hand-drawing-horizontal;
    p-fragment {
      @extend .property-hand-drawing-horizontal;
    }
  }
</style>
