---
import { Image } from "astro:assets";
import qrRepo from "../img/qr_repo.png";
const repoLink =
  "https://github.com/marcopollacci/talk-mcp-silent-colleague-code-example";
---

<p-slide class="center">
  <h2 style="margin-block-end: 0.3em">You can see the code on</h2>
  <p-note style="margin-block-end: 0.5em">
    <Image src={qrRepo} alt="qrcode slide" class="alter-image-size" />
  </p-note>
  <p-note>
    <a href={repoLink}>{repoLink}</a>
  </p-note>
</p-slide>
